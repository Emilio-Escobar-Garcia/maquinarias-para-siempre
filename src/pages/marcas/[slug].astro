---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import OtherReferenceCTA from '../../components/OtherReferenceCTA.astro';
import { getWhatsAppUrl, siteConfig, sortProductsByCommercialPriority } from '../../site.config';

export async function getStaticPaths() {
	const brands = (await getCollection('brands')).filter((brand) => !brand.data.draft);
	return brands.map((brand) => ({
		params: { slug: brand.data.slug },
		props: { brand },
	}));
}

const { brand } = Astro.props;
const products = sortProductsByCommercialPriority(
	(await getCollection('products')).filter(
		(product) => !product.data.draft && product.data.brand.id === brand.id
	)
);
const title = brand.data.seoTitle ?? `${brand.data.name} | Maquinarias para Siempre`;
const description = brand.data.seoDescription ?? brand.data.shortDescription;
const isKrpan = brand.data.slug === 'krpan';
const isMill = brand.data.slug === 'mill-industrias';
const isFormiko = brand.data.slug === 'formiko-hydraulics';
const brandRelationship = isKrpan
	? `${siteConfig.legalName} es ${siteConfig.krpanRelationship}.`
	: `${brand.data.name} es ${siteConfig.representedBrandRelationship}.`;
const brandMessage = `Hola, quiero consultar productos, referencias o configuraciones de ${brand.data.name}.`;
const krpanLines = [
	{
		name: 'Winches forestales',
		text: 'Equipos para arrastre y extracción de madera en operaciones forestales.',
	},
	{
		name: 'Grúas forestales',
		text: 'Equipos para apoyar la carga, descarga y manipulación de madera.',
	},
	{
		name: 'Grapas forestales',
		text: 'Implementos para sujetar, cargar y manipular troncos.',
	},
	{
		name: 'Traileres forestales',
		text: 'Equipos para transporte de madera y materiales forestales.',
	},
	{
		name: 'Accesorios relacionados',
		text: 'Otros equipos y accesorios forestales consultables según operación.',
	},
];
const millLines = [
	{
		name: 'Mill Máquinas',
		text: 'Maquinaria y soluciones para serrerías y procesamiento industrial de madera, orientadas a procesos de aserrío, líneas de corte y procesamiento de toras y madera.',
		image: '/images/solutions/mill/mill-maquinas-referencia.png',
		imageAlt: 'Imagen oficial de referencia de maquinaria Mill Máquinas',
		examples: ['Equipos para aserrío', 'Líneas de corte', 'Procesamiento de toras y madera'],
	},
	{
		name: 'Mill Serras',
		text: 'Sierras y herramientas de corte para procesos industriales, con soluciones de corte para madera y aplicaciones relacionadas dentro de procesos productivos.',
		image: '/images/solutions/mill/mill-serras-referencia.webp',
		imageAlt: 'Imagen oficial de referencia de Mill Serras',
		examples: ['Hojas de sierra cinta', 'Soluciones de corte para madera', 'Aplicaciones industriales'],
	},
];
const formikoLines = [
	{
		name: 'Rotadores hidráulicos',
		text: 'Componentes para aplicaciones forestales, agrícolas y de manejo de materiales.',
	},
	{
		name: 'Elementos de unión para rotadores',
		text: 'Componentes de conexión asociados a rotadores hidráulicos.',
	},
	{
		name: 'Amortiguadores de oscilación',
		text: 'Elementos orientados al control de la oscilación según la aplicación.',
	},
];
const brandLines = isKrpan ? krpanLines : isMill ? millLines : isFormiko ? formikoLines : [];
---

<BaseLayout title={title} description={description}>
	<section class="page-hero">
		<div class="container">
			<p class="eyebrow">Marca</p>
			{
				brand.data.logo && (
					<div class="brand-logo">
						<img src={brand.data.logo} alt={brand.data.logoAlt ?? `Logo de ${brand.data.name}`} />
					</div>
				)
			}
			<h1>{brand.data.name}</h1>
			<p class="lead">{brand.data.shortDescription}</p>
			{brand.data.description && <p>{brand.data.description}</p>}
			<div class="button-row">
				<a class="button button--dark" href="/marcas/">Ver marcas</a>
				{brand.data.officialWebsite && (
					<a class="button button--dark" href={brand.data.officialWebsite} target="_blank" rel="noopener noreferrer">
						Visitar sitio oficial
					</a>
				)}
			</div>
		</div>
	</section>
	<section class="section section--compact">
		<div class="container">
			<div class="brand-note">
				<h2>{brand.data.name} en Colombia</h2>
				<p>
					{brandRelationship} Las referencias y configuraciones se revisan para cada consulta comercial, sujetas a disponibilidad del fabricante y confirmación en la cotización.
				</p>
			</div>
		</div>
	</section>
	{
		brandLines.length > 0 && (
			<section class="section section--compact">
				<div class="container">
					<div class="section-heading">
						<div>
							<p class="eyebrow">Líneas</p>
							<h2>{isKrpan ? 'Líneas forestales de Krpan' : isMill ? 'Líneas principales de Mill Indústrias' : 'Líneas generales de Formiko Hydraulics'}</h2>
						</div>
						<p>
							{isMill
								? 'Mill Indústrias reúne soluciones para el procesamiento de madera en dos líneas principales. Las referencias y configuraciones se confirman para cada cotización.'
								: 'Estas líneas orientan la consulta comercial. Las referencias, compatibilidades y configuraciones se confirman para cada cotización.'}
						</p>
					</div>
					<div class={`brand-lines ${isKrpan ? 'brand-lines--wide' : ''} ${isMill ? 'brand-lines--visual' : ''}`}>
						{brandLines.map((line) => (
							<article class="brand-line">
								{line.image && <img src={line.image} alt={line.imageAlt ?? `${line.name} de referencia`} loading="lazy" />}
								<h3>{line.name}</h3>
								<p>{line.text}</p>
								{line.examples && (
									<ul>
										{line.examples.map((example) => <li>{example}</li>)}
									</ul>
								)}
							</article>
						))}
					</div>
				</div>
			</section>
		)
	}
	<section class="section">
		<div class="container">
			<div class="section-heading">
				<div>
					<p class="eyebrow">Productos</p>
					<h2>Productos de esta marca</h2>
				</div>
				<p>Listado de productos asociados a esta marca dentro del catálogo publicado.</p>
			</div>
			{
				products.length > 0 ? (
					<div class="grid grid--cards">
						{products.map((product) => <ProductCard product={product} />)}
					</div>
				) : (
					<div class="brand-empty">
						<p>Estamos preparando la información de esta línea. También puedes contactarnos para consultar equipos, referencias y configuraciones disponibles de esta marca.</p>
						<a class="button" href={getWhatsAppUrl(brandMessage)}>Consultar productos de esta marca</a>
					</div>
				)
			}
		</div>
	</section>
	<section class="section section--compact">
		<div class="container">
			<OtherReferenceCTA message={`Hola, quiero consultar otro modelo o configuración de ${brand.data.name}.`} />
		</div>
	</section>
</BaseLayout>

<style>
	.brand-note {
		padding: 24px;
		border: 1px solid rgba(74, 163, 223, 0.28);
		border-radius: var(--radius-md);
		background: #ffffff;
	}

	.brand-note h2 {
		font-size: clamp(1.35rem, 2.4vw, 1.85rem);
	}

	.brand-note p {
		max-width: 820px;
		color: var(--color-muted);
	}

	.brand-empty {
		display: grid;
		gap: 16px;
		max-width: 760px;
		padding: 24px;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		background: #ffffff;
	}

	.brand-empty p {
		margin: 0;
		color: var(--color-muted);
	}

	.brand-empty .button {
		justify-self: start;
	}

	.brand-lines {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 14px;
	}

	.brand-line {
		display: flex;
		flex-direction: column;
		gap: 10px;
		padding: 18px;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		background: #ffffff;
		color: inherit;
	}

	.brand-line img {
		width: calc(100% + 36px);
		aspect-ratio: 4 / 3;
		margin: -18px -18px 8px;
		border-bottom: 1px solid var(--color-border);
		background: #ffffff;
		object-fit: cover;
	}

	.brand-line h3 {
		margin: 0;
		color: var(--color-ink);
	}

	.brand-line p {
		margin: 0;
		color: var(--color-muted);
	}

	.brand-line ul {
		display: grid;
		gap: 6px;
		margin: auto 0 0;
		padding: 0;
		list-style: none;
		color: var(--color-muted);
	}

	.brand-line li {
		position: relative;
		padding-left: 14px;
	}

	.brand-line li::before {
		position: absolute;
		top: 0.72em;
		left: 0;
		width: 5px;
		height: 5px;
		border-radius: 999px;
		background: var(--color-accent-strong);
		content: '';
	}

	.brand-lines--wide {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.brand-lines--visual .brand-line {
		min-height: 100%;
		overflow: hidden;
		padding: 18px;
	}

	.brand-logo {
		display: grid;
		place-items: center;
		width: min(220px, 100%);
		margin-bottom: 18px;
		padding: 16px;
		border: 1px solid rgba(255, 255, 255, 0.18);
		border-radius: var(--radius-md);
		background: rgba(8, 29, 54, 0.76);
	}

	.brand-logo img {
		display: block;
		width: 100%;
		max-height: 94px;
		object-fit: contain;
	}

	@media (max-width: 680px) {
		.brand-lines,
		.brand-lines--wide {
			grid-template-columns: 1fr;
		}
	}
</style>
