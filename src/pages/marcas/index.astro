---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BrandCard from '../../components/BrandCard.astro';

const brands = (await getCollection('brands'))
	.filter((brand) => !brand.data.draft)
	.sort((a, b) => a.data.name.localeCompare(b.data.name, 'es'));
---

<BaseLayout title="Marcas | Maquinarias para Siempre" description="Marcas representadas por Maquinarias para Siempre en Colombia.">
	<section class="page-hero">
		<div class="container">
			<p class="eyebrow">Catálogo</p>
			<h1>Marcas</h1>
			<p class="lead">Fabricantes especializados y líneas representadas por Maquinarias para Siempre en Colombia.</p>
			<p>El catálogo web muestra solo una parte de las referencias que pueden consultarse. Cada disponibilidad, configuración y plazo se confirma para la cotización.</p>
		</div>
	</section>
	<section class="section">
		<div class="container">
			<div class="section-heading">
				<div>
					<p class="eyebrow">Fabricantes</p>
					<h2>Marcas publicadas</h2>
				</div>
				<p>Estas páginas agrupan productos publicados y consultas por marca, sin prometer inventario permanente.</p>
			</div>
			{
				brands.length > 0 ? (
					<div class="grid grid--cards">
						{brands.map((brand) => <BrandCard brand={brand} />)}
					</div>
				) : (
					<p class="empty-state">Todavía no hay marcas publicadas.</p>
				)
			}
		</div>
	</section>
</BaseLayout>
