---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Página no encontrada | Maquinarias para Siempre" description="La página solicitada no existe.">
	<section class="page-hero not-found">
		<div class="container">
			<p class="eyebrow">Error 404</p>
			<h1>Página no encontrada</h1>
			<p class="lead">La página que buscas no existe o cambió de ubicación.</p>
			<div class="button-row">
				<a class="button" href="/">Volver al inicio</a>
				<a class="button button--dark" href="/productos/">Ver productos</a>
			</div>
		</div>
	</section>
</BaseLayout>
