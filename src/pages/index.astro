---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import CategoryCard from '../components/CategoryCard.astro';
import BrandCard from '../components/BrandCard.astro';
import ContactCTA from '../components/ContactCTA.astro';
import HomeScroller from '../components/HomeScroller.astro';
import SparePartsCTA from '../components/SparePartsCTA.astro';
import { commercialSolutions, getWhatsAppUrl, siteConfig, sortProductsByCommercialPriority } from '../site.config';

const products = sortProductsByCommercialPriority(
	(await getCollection('products')).filter((product) => !product.data.draft)
);
const featuredProducts = products.filter((product) => product.data.featured);
const categories = (await getCollection('categories'))
	.filter((category) => !category.data.draft)
	.sort((a, b) => a.data.order - b.data.order);
const brands = (await getCollection('brands'))
	.filter((brand) => !brand.data.draft)
	.sort((a, b) => a.data.name.localeCompare(b.data.name, 'es'));
const homeCategories = categories.slice(0, 8);
const homeFeaturedProducts = featuredProducts.slice(0, 8);
const homeBrands = brands.slice(0, 8);
---

<BaseLayout title={`${siteConfig.name} | Maquinaria forestal`} description={siteConfig.description}>
	<section class="section hero">
		<div class="container hero-grid">
			<div class="hero-copy">
				<p class="eyebrow">Maquinarias para Siempre</p>
				<h1>Maquinaria forestal para las exigencias del campo colombiano</h1>
				<p class="lead">
					Maquinaria, equipos, sierras y repuestos para operaciones forestales y procesamiento de madera en Colombia.
				</p>
				<div class="button-row">
					<a class="button" href="/productos/">Ver productos</a>
					<a class="button button--dark" href={getWhatsAppUrl()}>Hablar por WhatsApp</a>
				</div>
			</div>
			<div class="hero-visual" aria-hidden="true">
				<div class="machine-card">
					<div class="machine-cabin"></div>
					<div class="machine-arm"></div>
					<div class="machine-line"></div>
					<div class="machine-base"></div>
					<div class="machine-wheel machine-wheel--left"></div>
					<div class="machine-wheel machine-wheel--right"></div>
				</div>
				<div class="visual-label visual-label--top">Catálogo técnico</div>
				<div class="visual-label visual-label--bottom">Cobertura Colombia</div>
			</div>
		</div>
	</section>

	<section class="section section--surface">
		<div class="container intro-grid">
			<div>
				<p class="eyebrow">Empresa</p>
				<h2>Maquinaria, equipos y repuestos para operaciones forestales</h2>
			</div>
			<div>
				<p>
					{siteConfig.companyIntro} La empresa atiende clientes en toda Colombia y trabaja con fabricantes especializados como Krpan, Formiko Hydraulics y Mill Indústrias.
				</p>
			</div>
		</div>
	</section>

	<section class="section">
		<div class="container">
			{
				homeCategories.length > 0 ? (
					<HomeScroller
						eyebrow="Categorías"
						title="Categorías de productos"
						description="Consulte las líneas publicadas para ubicar el tipo de equipo que necesita."
						allHref="/categorias/"
						allLabel="Ver todas las categorías"
						variant="categories"
					>
						{homeCategories.map((category) => <CategoryCard category={category} />)}
					</HomeScroller>
				) : (
					<p class="empty-state">Todavía no hay categorías publicadas.</p>
				)
			}
		</div>
	</section>

	<section class="section section--surface">
		<div class="container">
			{
				homeFeaturedProducts.length > 0 ? (
					<HomeScroller
						eyebrow="Destacados"
						title="Productos destacados"
						description="Referencias relevantes para iniciar una consulta comercial, sin prometer inventario ni plazo de entrega."
						allHref="/productos/"
						allLabel="Ver todos los productos"
						variant="products"
					>
						{homeFeaturedProducts.map((product) => <ProductCard product={product} />)}
					</HomeScroller>
				) : (
					<p class="empty-state">Todavía no hay productos destacados publicados.</p>
				)
			}
		</div>
	</section>

	<section class="section section--compact">
		<div class="container">
			<SparePartsCTA />
		</div>
	</section>

	<section class="section">
		<div class="container">
			{
				homeBrands.length > 0 ? (
					<HomeScroller
						eyebrow="Marcas"
						title="Marcas en el catálogo"
						description="Fabricantes y líneas representadas por Maquinarias para Siempre en Colombia."
						allHref="/marcas/"
						allLabel="Ver todas las marcas"
						variant="brands"
					>
						{homeBrands.map((brand) => <BrandCard brand={brand} />)}
					</HomeScroller>
				) : (
					<p class="empty-state">Todavía no hay marcas publicadas.</p>
				)
			}
		</div>
	</section>

	<section class="section section--surface">
		<div class="container">
			<div class="section-heading">
				<div>
					<p class="eyebrow">Soluciones</p>
					<h2>Soluciones para operaciones forestales y procesamiento de madera</h2>
				</div>
				<p>Estas líneas orientan la consulta inicial. Las referencias, configuraciones y disponibilidad se confirman en cada cotización.</p>
			</div>
			<div class="grid solution-grid">
				{
					commercialSolutions.map((solution) => (
						<article class="card solution-card">
							<a href={solution.href}>
								{solution.image ? (
									<img src={solution.image} alt={solution.alt} loading="lazy" />
								) : (
									<div class="solution-placeholder" aria-hidden="true">RP</div>
								)}
								<div>
									<h3>{solution.title}</h3>
									<p>{solution.text}</p>
									<span>Consultar línea</span>
								</div>
							</a>
						</article>
					))
				}
			</div>
		</div>
	</section>

	<section class="section">
		<div class="container">
			<div class="coverage">
				<div>
					<p class="eyebrow">Cobertura</p>
					<h2>Atención desde {siteConfig.location} hacia Colombia</h2>
					<p>
						Recibimos consultas comerciales desde Medellín y atendemos necesidades de maquinaria, equipos y repuestos en {siteConfig.coverage}.
					</p>
				</div>
				<div class="coverage-map" aria-hidden="true">
					<span></span>
					<span></span>
					<span></span>
				</div>
			</div>
		</div>
	</section>

	<section class="section section--compact">
		<div class="container">
			<ContactCTA />
		</div>
	</section>
</BaseLayout>

<style>
	.hero {
		position: relative;
		min-height: 680px;
		display: grid;
		align-items: center;
		background:
			linear-gradient(135deg, rgba(8, 29, 54, 0.98), rgba(15, 61, 99, 0.92)),
			radial-gradient(circle at 80% 20%, rgba(74, 163, 223, 0.24), transparent 30%);
		color: #ffffff;
		overflow: hidden;
	}

	.hero::before {
		content: '';
		position: absolute;
		inset: 0;
		background:
			linear-gradient(90deg, rgba(255, 255, 255, 0.05) 1px, transparent 1px),
			linear-gradient(0deg, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
		background-size: 56px 56px;
		mask-image: linear-gradient(90deg, black, transparent 70%);
	}

	.hero-grid {
		position: relative;
		z-index: 1;
		display: grid;
		grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
		gap: 44px;
		align-items: center;
	}

	.hero-copy .lead {
		color: rgba(255, 255, 255, 0.78);
	}

	.hero-visual {
		position: relative;
		min-height: 430px;
		border: 1px solid rgba(255, 255, 255, 0.16);
		border-radius: 18px;
		background:
			linear-gradient(135deg, rgba(255, 255, 255, 0.13), rgba(255, 255, 255, 0.04)),
			repeating-linear-gradient(135deg, rgba(255, 255, 255, 0.08) 0 1px, transparent 1px 16px);
		box-shadow: 0 30px 80px rgba(0, 0, 0, 0.24);
		overflow: hidden;
	}

	.hero-visual::before {
		content: '';
		position: absolute;
		inset: 42px;
		border: 1px solid rgba(255, 255, 255, 0.12);
		border-radius: 50%;
	}

	.machine-card {
		position: absolute;
		left: 50%;
		top: 52%;
		width: min(78%, 410px);
		height: 210px;
		transform: translate(-50%, -50%);
	}

	.machine-cabin,
	.machine-arm,
	.machine-line,
	.machine-base,
	.machine-wheel {
		position: absolute;
	}

	.machine-base {
		left: 62px;
		bottom: 50px;
		width: 250px;
		height: 54px;
		border-radius: 10px 24px 12px 12px;
		background: linear-gradient(180deg, #8ed0ff, #3c98d1);
	}

	.machine-cabin {
		left: 92px;
		bottom: 100px;
		width: 86px;
		height: 74px;
		clip-path: polygon(20% 0, 100% 0, 100% 100%, 0 100%, 0 28%);
		background: linear-gradient(145deg, #d9f0ff, #6bbbe9);
	}

	.machine-arm {
		left: 172px;
		bottom: 132px;
		width: 170px;
		height: 14px;
		border-radius: 999px;
		background: #b6e0fb;
		transform: rotate(-18deg);
		transform-origin: left center;
	}

	.machine-line {
		right: 34px;
		bottom: 72px;
		width: 2px;
		height: 116px;
		background: rgba(255, 255, 255, 0.7);
	}

	.machine-wheel {
		bottom: 20px;
		width: 78px;
		height: 78px;
		border: 12px solid #0b223d;
		border-radius: 50%;
		background: #8ed0ff;
		box-shadow: inset 0 0 0 12px #2f6f5d;
	}

	.machine-wheel--left {
		left: 82px;
	}

	.machine-wheel--right {
		left: 230px;
	}

	.visual-label {
		position: absolute;
		padding: 10px 14px;
		border: 1px solid rgba(255, 255, 255, 0.22);
		border-radius: 999px;
		background: rgba(8, 29, 54, 0.62);
		color: #ffffff;
		font-weight: 800;
	}

	.visual-label--top {
		top: 26px;
		left: 24px;
	}

	.visual-label--bottom {
		right: 24px;
		bottom: 26px;
	}

	.intro-grid {
		display: grid;
		grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
		gap: 32px;
		align-items: start;
	}

	.solution-grid {
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 230px), 1fr));
	}

	.solution-card {
		padding: 0;
		overflow: hidden;
	}

	.solution-card a {
		display: flex;
		flex-direction: column;
		height: 100%;
		color: inherit;
		text-decoration: none;
	}

	.solution-card img,
	.solution-placeholder {
		width: 100%;
		aspect-ratio: 4 / 3;
		border-bottom: 1px solid var(--color-border);
		background: #ffffff;
		object-fit: contain;
	}

	.solution-placeholder {
		display: grid;
		place-items: center;
		background:
			linear-gradient(135deg, rgba(15, 47, 86, 0.92), rgba(74, 163, 223, 0.8)),
			var(--color-primary);
		color: #ffffff;
		font-weight: 900;
		letter-spacing: 0.06em;
	}

	.solution-card div:not(.solution-placeholder) {
		display: flex;
		flex: 1;
		flex-direction: column;
		padding: 20px;
	}

	.solution-card p {
		color: var(--color-muted);
	}

	.solution-card span {
		margin-top: auto;
		color: var(--color-primary);
		font-weight: 800;
	}

	.coverage {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(240px, 380px);
		gap: 28px;
		align-items: center;
		padding: clamp(24px, 4vw, 36px);
		border-radius: var(--radius-md);
		background: var(--color-primary);
		color: #ffffff;
		box-shadow: var(--shadow-soft);
		overflow: hidden;
	}

	.coverage h2,
	.coverage .eyebrow {
		color: #ffffff;
	}

	.coverage p {
		color: rgba(255, 255, 255, 0.78);
	}

	.coverage-map {
		position: relative;
		min-height: 250px;
		border: 1px solid rgba(255, 255, 255, 0.16);
		border-radius: 16px;
		background:
			radial-gradient(circle at 45% 45%, rgba(142, 208, 255, 0.36), transparent 8%),
			linear-gradient(135deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.04)),
			repeating-linear-gradient(45deg, rgba(255, 255, 255, 0.08) 0 1px, transparent 1px 16px);
	}

	.coverage-map span {
		position: absolute;
		border: 1px solid rgba(255, 255, 255, 0.24);
		border-radius: 50%;
		transform: translate(-50%, -50%);
	}

	.coverage-map span:nth-child(1) {
		left: 50%;
		top: 50%;
		width: 70px;
		height: 70px;
	}

	.coverage-map span:nth-child(2) {
		left: 50%;
		top: 50%;
		width: 140px;
		height: 140px;
	}

	.coverage-map span:nth-child(3) {
		left: 50%;
		top: 50%;
		width: 210px;
		height: 210px;
	}

	@media (max-width: 900px) {
		.hero {
			min-height: auto;
			padding-top: 76px;
		}

		.hero-grid,
		.intro-grid,
		.coverage {
			grid-template-columns: 1fr;
		}

		.solution-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 560px) {
		.solution-grid {
			grid-template-columns: 1fr;
		}

		.hero-visual {
			min-height: 320px;
		}

		.machine-card {
			width: 92%;
			transform: translate(-50%, -50%) scale(0.78);
		}

		.visual-label {
			font-size: 0.82rem;
		}
	}
</style>
