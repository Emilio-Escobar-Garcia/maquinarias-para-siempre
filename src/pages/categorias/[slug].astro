---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import OtherReferenceCTA from '../../components/OtherReferenceCTA.astro';
import { getWhatsAppUrl, sortProductsByCommercialPriority } from '../../site.config';

export async function getStaticPaths() {
	const categories = (await getCollection('categories')).filter((category) => !category.data.draft);
	return categories.map((category) => ({
		params: { slug: category.data.slug },
		props: { category },
	}));
}

const { category } = Astro.props;
const products = sortProductsByCommercialPriority(
	(await getCollection('products')).filter(
		(product) => !product.data.draft && product.data.category.id === category.id
	)
);
const title = category.data.seoTitle ?? `${category.data.name} | Maquinarias para Siempre`;
const description = category.data.seoDescription ?? category.data.shortDescription;
const advisorMessage = `Hola, quiero consultar una referencia o configuración de ${category.data.name}.`;
---

<BaseLayout title={title} description={description}>
	<section class="page-hero">
		<div class="container">
			<p class="eyebrow">Categoría</p>
			<h1>{category.data.name}</h1>
			<p class="lead">{category.data.shortDescription}</p>
			{category.data.description && <p>{category.data.description}</p>}
			{
				category.data.alternativeTerms.length > 0 && (
					<ul class="pill-list">
						{category.data.alternativeTerms.map((term) => <li>{term}</li>)}
					</ul>
				)
			}
			<div class="button-row">
				<a class="button button--dark" href="/categorias/">Ver categorías</a>
				<a class="button button--dark" href="/productos/">Ver productos</a>
			</div>
		</div>
	</section>
	{
		category.data.intro && (
			<section class="section section--compact">
				<div class="container">
					<div class="category-intro">
						<p class="eyebrow">Guía de selección</p>
						<h2>{category.data.intro.title}</h2>
						<p>{category.data.intro.body}</p>
					</div>
				</div>
			</section>
		)
	}
	{
		category.data.image && (
			<section class="section section--compact">
				<div class="container">
					<figure class="category-reference">
						<img src={category.data.image} alt={category.data.imageAlt ?? `${category.data.name} de referencia`} />
						{category.data.imageCaption && <figcaption>{category.data.imageCaption}</figcaption>}
					</figure>
				</div>
			</section>
		)
	}
	{
		category.data.selectionFactors.length > 0 && (
			<section class="section section--compact">
				<div class="container">
					<div class="section-heading section-heading--stacked">
						<div>
							<p class="eyebrow">Selección</p>
							<h2>Qué debes tener en cuenta</h2>
						</div>
						<p>Estos puntos orientan la conversación inicial. La configuración se confirma siempre para cada cotización.</p>
					</div>
					<div class="factor-grid">
						{category.data.selectionFactors.map((factor) => (
							<article class="factor-card">
								<h3>{factor.title}</h3>
								<p>{factor.text}</p>
							</article>
						))}
					</div>
				</div>
			</section>
		)
	}
	<section class="section">
		<div class="container">
			<div class="section-heading">
				<div>
					<p class="eyebrow">Productos</p>
					<h2>Productos en esta categoría</h2>
				</div>
				<p>Equipos asociados a esta categoría dentro del catálogo publicado.</p>
			</div>
			{
				products.length > 0 ? (
					<div class="grid grid--cards">
						{products.map((product) => <ProductCard product={product} />)}
					</div>
				) : (
					<div class="category-empty">
						<p>{category.data.emptyProductsText ?? 'Todavía no hay productos publicados en esta categoría. Podemos revisar referencias y configuraciones bajo consulta comercial.'}</p>
						<a class="button" href={getWhatsAppUrl(advisorMessage)}>{category.data.advisorButtonLabel ?? 'Consultar esta categoría'}</a>
					</div>
				)
			}
		</div>
	</section>
	{
		category.data.advisorText && (
			<section class="section section--compact">
				<div class="container">
					<div class="advisory-note">
						<div>
							<p class="eyebrow">Asesoría</p>
							<h2>Consulta comercial de {category.data.name.toLowerCase()}</h2>
							<p>{category.data.advisorText}</p>
						</div>
						<a class="button" href={getWhatsAppUrl(advisorMessage)}>{category.data.advisorButtonLabel ?? 'Consultar esta categoría'}</a>
					</div>
				</div>
			</section>
		)
	}
	<section class="section section--compact">
		<div class="container">
			<OtherReferenceCTA message={`Hola, quiero consultar otra referencia o configuración de ${category.data.name}.`} />
		</div>
	</section>
</BaseLayout>

<style>
	.category-intro {
		max-width: 860px;
	}

	.category-intro h2 {
		font-size: clamp(1.5rem, 2.6vw, 2.1rem);
	}

	.category-intro p:not(.eyebrow) {
		color: var(--color-muted);
	}

	.category-reference {
		margin: 0;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		background: #ffffff;
		overflow: hidden;
	}

	.category-reference img {
		display: block;
		width: 100%;
		max-height: 340px;
		object-fit: contain;
	}

	.category-reference figcaption {
		padding: 10px 14px;
		border-top: 1px solid var(--color-border);
		color: var(--color-muted);
		font-size: 0.92rem;
	}

	.factor-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 14px;
	}

	.factor-card,
	.category-empty,
	.advisory-note {
		padding: 20px;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		background: #ffffff;
	}

	.factor-card h3 {
		margin-bottom: 8px;
		color: var(--color-ink);
		font-size: 1.05rem;
	}

	.factor-card p,
	.category-empty p,
	.advisory-note p:not(.eyebrow) {
		margin: 0;
		color: var(--color-muted);
	}

	.category-empty {
		display: grid;
		gap: 16px;
		max-width: 780px;
	}

	.category-empty .button {
		justify-self: start;
	}

	.advisory-note {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 20px;
	}

	.advisory-note h2 {
		font-size: clamp(1.35rem, 2.4vw, 1.85rem);
	}

	.advisory-note p:not(.eyebrow) {
		max-width: 780px;
	}

	.advisory-note .button {
		flex: 0 0 auto;
	}

	@media (max-width: 720px) {
		.factor-grid {
			grid-template-columns: 1fr;
		}

		.category-reference img {
			max-height: 280px;
		}

		.advisory-note {
			align-items: start;
			flex-direction: column;
		}
	}
</style>
