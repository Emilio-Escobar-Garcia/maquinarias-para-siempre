---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryCard from '../../components/CategoryCard.astro';
import OtherReferenceCTA from '../../components/OtherReferenceCTA.astro';

const categories = (await getCollection('categories'))
	.filter((category) => !category.data.draft)
	.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Categorías | Maquinarias para Siempre" description="Categorías de maquinaria forestal del catálogo.">
	<section class="page-hero">
		<div class="container">
			<p class="eyebrow">Catálogo</p>
			<h1>Categorías</h1>
			<p class="lead">Organización inicial del catálogo por tipo de maquinaria forestal.</p>
		</div>
	</section>
	<section class="section">
		<div class="container">
			<div class="section-heading">
				<div>
					<p class="eyebrow">Líneas</p>
					<h2>Categorías del catálogo</h2>
				</div>
				<p>Encuentre productos según el tipo de trabajo o equipo que necesita.</p>
			</div>
			{
				categories.length > 0 ? (
					<div class="grid grid--cards category-grid">
						{categories.map((category) => <CategoryCard category={category} />)}
					</div>
				) : (
					<p class="empty-state">Todavía no hay categorías publicadas.</p>
				)
			}
		</div>
	</section>
	<section class="section section--compact">
		<div class="container">
			<OtherReferenceCTA />
		</div>
	</section>
</BaseLayout>

<style>
	.category-grid {
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 280px), 1fr));
	}

	@media (min-width: 980px) {
		.category-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}
</style>
