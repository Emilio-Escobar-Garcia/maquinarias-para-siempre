---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactCTA from '../../components/ContactCTA.astro';
import SparePartsCTA from '../../components/SparePartsCTA.astro';
import { commercialSolutions, siteConfig } from '../../site.config';
---

<BaseLayout title="Nosotros | Maquinarias para Siempre" description={siteConfig.description}>
	<section class="page-hero">
		<div class="container">
			<p class="eyebrow">Nosotros</p>
			<h1>{siteConfig.name}</h1>
			<p class="lead">{siteConfig.description}</p>
		</div>
	</section>
	<section class="section">
		<div class="container about-grid">
			<div>
				<p class="eyebrow">Empresa</p>
				<h2>Atención comercial para operaciones forestales en Colombia</h2>
				<p>
					{siteConfig.companyIntro}
				</p>
				<p>
					Maquinarias para Siempre S.A.S. representa en Colombia fabricantes especializados en maquinaria forestal, equipos hidráulicos, sierras y soluciones para el procesamiento de madera. Su portafolio incluye marcas como Krpan, Formiko Hydraulics y Mill Indústrias, con atención comercial desde Medellín, Antioquia, y cobertura en todo el país.
				</p>
				<p>
					Nuestro canal principal de atención es directo: revisamos cada consulta por WhatsApp o correo para orientar la conversación comercial de forma clara.
				</p>
			</div>
			<div class="about-visual">
				<img src={siteConfig.logo} alt="Maquinarias para Siempre" />
			</div>
		</div>
	</section>
	<section class="section section--surface">
		<div class="container">
			<div class="section-heading">
				<div>
					<p class="eyebrow">Enfoque</p>
					<h2>Soluciones para operaciones forestales y procesamiento de madera</h2>
				</div>
				<p>Estas líneas orientan la conversación comercial sin convertirlas en fichas de producto publicadas.</p>
			</div>
			<div class="grid service-grid">
				{
					commercialSolutions.map((solution) => (
						<article class="card service-card">
							<h3>{solution.title}</h3>
							<p>{solution.text}</p>
							<a href={solution.href}>Consultar línea</a>
						</article>
					))
				}
			</div>
		</div>
	</section>
	<section class="section">
		<div class="container">
			<div class="section-heading">
				<div>
					<p class="eyebrow">Atención</p>
					<h2>Asesoría y cobertura comercial</h2>
				</div>
			</div>
			<div class="grid service-grid">
				<article class="card service-card">
					<h3>Selección de equipos</h3>
					<p>Orientación para revisar alternativas según el tipo de operación, configuración y disponibilidad confirmada para cada cotización.</p>
				</article>
				<article class="card service-card">
					<h3>Cobertura nacional</h3>
					<p>Atención desde {siteConfig.location} para consultas comerciales en {siteConfig.coverage}.</p>
				</article>
				<article class="card service-card">
					<h3>Canales de contacto</h3>
					<p>{siteConfig.contactAvailability} Cuéntenos qué equipo busca y las condiciones generales de su operación.</p>
				</article>
			</div>
		</div>
	</section>
	<section class="section section--compact">
		<div class="container">
			<SparePartsCTA />
		</div>
	</section>
	<section class="section section--compact">
		<div class="container">
			<ContactCTA />
		</div>
	</section>
</BaseLayout>

<style>
	.about-grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(280px, 0.75fr);
		gap: 28px;
		align-items: center;
	}

	.about-visual {
		display: grid;
		place-items: center;
		min-height: 300px;
		padding: clamp(20px, 4vw, 36px);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		background: #ffffff;
		box-shadow: var(--shadow-soft);
	}

	.about-visual img {
		display: block;
		width: 100%;
		height: auto;
		max-height: 280px;
		object-fit: contain;
	}

	.service-grid {
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 240px), 1fr));
	}

	.service-card {
		display: flex;
		flex-direction: column;
	}

	.service-card p {
		color: var(--color-muted);
	}

	.service-card a {
		margin-top: auto;
		color: var(--color-primary);
		font-weight: 800;
		text-decoration: none;
	}

	@media (max-width: 800px) {
		.about-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
