---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import OtherReferenceCTA from '../../components/OtherReferenceCTA.astro';
import { sortProductsByCommercialPriority } from '../../site.config';

const products = sortProductsByCommercialPriority(
	(await getCollection('products')).filter((product) => !product.data.draft)
);
---

<BaseLayout title="Productos | Maquinarias para Siempre" description="Catálogo de maquinaria forestal para consulta comercial.">
	<section class="page-hero">
		<div class="container">
			<p class="eyebrow">Catálogo</p>
			<h1>Productos</h1>
			<p class="lead">Referencias publicadas para orientar consultas comerciales y cotizaciones.</p>
		</div>
	</section>
	<section class="section">
		<div class="container">
			<div class="section-heading">
				<div>
					<p class="eyebrow">Listado</p>
					<h2>Productos publicados</h2>
				</div>
				<p>Revise las referencias publicadas y contáctenos para confirmar configuración, disponibilidad y plazo de entrega.</p>
			</div>
			{
				products.length > 0 ? (
					<div class="grid grid--cards">
						{products.map((product) => <ProductCard product={product} />)}
					</div>
				) : (
					<p class="empty-state">Todavía no hay productos publicados.</p>
				)
			}
		</div>
	</section>
	<section class="section section--compact">
		<div class="container">
			<OtherReferenceCTA />
		</div>
	</section>
</BaseLayout>
