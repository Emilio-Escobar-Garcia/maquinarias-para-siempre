---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import OtherReferenceCTA from '../../components/OtherReferenceCTA.astro';
import { getWhatsAppUrl, siteConfig, sortProductsByCommercialPriority } from '../../site.config';

export async function getStaticPaths() {
	const products = (await getCollection('products')).filter((product) => !product.data.draft);
	return products.map((product) => ({
		params: { slug: product.data.slug },
		props: { product },
	}));
}

const { product } = Astro.props;
const brand = await getEntry(product.data.brand);
const category = await getEntry(product.data.category);
const relatedProducts = product.data.relatedProducts
	? await Promise.all(product.data.relatedProducts.map((related) => getEntry(related)))
	: [];
const visibleRelatedProducts = sortProductsByCommercialPriority(
	relatedProducts.filter((entry) => entry && !entry.data.draft)
);
const title = product.data.seoTitle ?? `${product.data.name} | Maquinarias para Siempre`;
const description = product.data.seoDescription ?? product.data.shortDescription;
const images = (product.data.images ?? []).map((image) =>
	typeof image === 'string' ? { src: image, alt: `Imagen de ${product.data.name}` } : image
);
const documents = (product.data.documents ?? []).map((documentUrl) =>
	typeof documentUrl === 'string'
		? { href: documentUrl, label: 'Ver documento PDF' }
		: documentUrl
);
const video =
	typeof product.data.video === 'string'
		? { url: product.data.video, label: 'Ver video' }
		: product.data.video;
const resources = [
	...documents.map((document) => ({
		type: 'document',
		title: document.label ?? 'Catálogo oficial',
		description: document.note,
		href: document.href,
		action: 'Descargar PDF',
	})),
	...(video
		? [
				{
					type: 'video',
					title: 'Video oficial de la serie EP/ERP',
					description: 'Material oficial del fabricante sobre la serie EP/ERP.',
					href: video.url,
					action: 'Ver video',
				},
			]
		: []),
];
const productMessage = `Hola, quiero recibir información sobre ${product.data.name}.`;
---

<BaseLayout title={title} description={description}>
	<section class="product-hero">
		<div class="container">
			<p class="eyebrow">Producto</p>
			<h1>{product.data.name}</h1>
			<p class="lead">{product.data.shortDescription}</p>
			<div class="product-tags">
				{brand && <a href={`/marcas/${brand.data.slug}/`}>{brand.data.name}</a>}
				{category && <a href={`/categorias/${category.data.slug}/`}>{category.data.name}</a>}
			</div>
		</div>
	</section>

	<section class="section">
		<div class="container product-layout">
			<article class="product-content">
				<section class="gallery" aria-label={`Galería de ${product.data.name}`}>
					{
						images.length > 0 ? (
							<figure class="gallery-main">
								<button type="button" class="gallery-open" data-gallery-open aria-label={`Ampliar imagen de ${product.data.name}`}>
									<img src={images[0].src} alt={images[0].alt} data-gallery-main />
								</button>
							</figure>
						) : (
							<div class="visual-placeholder gallery-main gallery-placeholder" aria-label="Espacio para imagen del producto">
								<span>Imagen del producto</span>
							</div>
						)
					}
					<div class="gallery-thumbs" aria-label="Miniaturas">
						{
							images.length > 0 ? (
								images.map((image, index) => (
									<button
										type="button"
										class={index === 0 ? 'is-active' : undefined}
										aria-label={`Ver imagen ${index + 1} de ${product.data.name}`}
										aria-pressed={index === 0 ? 'true' : 'false'}
										data-gallery-thumb
										data-gallery-src={image.src}
										data-gallery-alt={image.alt}
									>
										<img src={image.src} alt="" loading="lazy" />
									</button>
								))
							) : (
								<button type="button" class="is-active" aria-label="Sin imagen disponible">
									<span></span>
								</button>
							)
						}
					</div>
					{product.data.imageNotice && <p class="gallery-note">{product.data.imageNotice}</p>}
				</section>

				<section class="content-block">
					<h2>Descripción y aplicaciones</h2>
					<p>{product.data.mainDescription}</p>
					{
						product.data.applications && product.data.applications.length > 0 && (
							<ul class="list">
								{product.data.applications.map((application) => <li>{application}</li>)}
							</ul>
						)
					}
				</section>

				{
					product.data.features.length > 0 && (
						<section class="content-block">
							<h2>Características principales</h2>
							<ul class="list">
								{product.data.features.map((feature) => <li>{feature}</li>)}
							</ul>
						</section>
					)
				}

				{
					product.data.specifications.length > 0 && (
						<section class="content-block">
							<h2>Especificaciones técnicas</h2>
							<dl class="spec-table">
								{product.data.specifications.map((spec) => (
									<div>
										<dt>{spec.name}</dt>
										<dd>{spec.value}</dd>
									</div>
								))}
							</dl>
						</section>
					)
				}

				{
					resources.length > 0 && (
						<section class="content-block">
							<h2>Recursos del producto</h2>
							<div class="resource-list">
								{resources.map((resource) => (
									<a href={resource.href} class="resource-item">
										<span class="resource-item__title">{resource.title}</span>
										{resource.description && <small>{resource.description}</small>}
										<span class="resource-item__action">{resource.action}</span>
									</a>
								))}
							</div>
						</section>
					)
				}
			</article>

			<aside class="product-sidebar">
				<div class="card side-card">
					<h2>Consulta comercial</h2>
					{product.data.availability && (
						<div class="availability-box">
							<h3>{siteConfig.availabilityHeading}</h3>
							<p>{siteConfig.availabilityText}</p>
						</div>
					)}
					<dl class="meta-list">
						<div>
							<dt>Marca</dt>
							<dd>{brand ? <a href={`/marcas/${brand.data.slug}/`}>{brand.data.name}</a> : 'Sin marca'}</dd>
						</div>
						<div>
							<dt>Categoría</dt>
							<dd>
								{category ? <a href={`/categorias/${category.data.slug}/`}>{category.data.name}</a> : 'Sin categoría'}
							</dd>
						</div>
						{product.data.officialSource && (
							<div>
								<dt>Fuente oficial</dt>
								<dd><a href={product.data.officialSource}>Consultar fuente</a></dd>
							</div>
						)}
					</dl>
					<div class="side-actions">
						<a class="button" href={getWhatsAppUrl(productMessage)}>Consultar por WhatsApp</a>
						<a class="button button--secondary" href={`mailto:${siteConfig.email}`}>Enviar correo</a>
					</div>
				</div>
			</aside>
		</div>
	</section>

	{
		visibleRelatedProducts.length > 0 && (
			<section class="section section--surface">
				<div class="container">
					<div class="section-heading">
						<div>
							<p class="eyebrow">Relacionados</p>
							<h2>Productos relacionados</h2>
						</div>
					</div>
					<div class="grid grid--cards">
						{visibleRelatedProducts.map((related) => related && <ProductCard product={related} />)}
					</div>
				</div>
			</section>
		)
	}

	<section class="section section--compact">
		<div class="container">
			<OtherReferenceCTA message={`Hola, quiero consultar otra referencia o configuración relacionada con ${product.data.name}.`} />
		</div>
	</section>

	<section class="section section--compact">
		<div class="container">
			<div class="final-product-cta">
				<div>
					<p class="eyebrow">Contacto</p>
					<h2>¿Quiere consultar este producto?</h2>
					<p>Comparta el nombre del equipo y el tipo de operación para recibir orientación comercial.</p>
				</div>
				<a class="button" href={getWhatsAppUrl(productMessage)}>Hablar por WhatsApp</a>
			</div>
		</div>
	</section>

	{
		images.length > 0 && (
			<dialog class="gallery-dialog" data-gallery-dialog aria-label={`Imagen ampliada de ${product.data.name}`}>
				<button type="button" class="gallery-dialog__close" data-gallery-close aria-label="Cerrar imagen ampliada">
					×
				</button>
				<img src={images[0].src} alt={images[0].alt} data-gallery-dialog-image />
			</dialog>
		)
	}

	<script>
		const galleries = document.querySelectorAll<HTMLElement>('.gallery');

		galleries.forEach((gallery) => {
			const mainImage = gallery.querySelector<HTMLImageElement>('[data-gallery-main]');
			const openButton = gallery.querySelector<HTMLButtonElement>('[data-gallery-open]');
			const thumbs = Array.from(gallery.querySelectorAll<HTMLButtonElement>('[data-gallery-thumb]'));
			const dialog = document.querySelector<HTMLDialogElement>('[data-gallery-dialog]');
			const dialogImage = document.querySelector<HTMLImageElement>('[data-gallery-dialog-image]');
			const closeButton = document.querySelector<HTMLButtonElement>('[data-gallery-close]');

			if (!mainImage) return;

			const setImage = (button: HTMLButtonElement) => {
				const src = button.dataset.gallerySrc;
				const alt = button.dataset.galleryAlt;
				if (!src || !alt) return;

				mainImage.src = src;
				mainImage.alt = alt;
				thumbs.forEach((thumb) => {
					const active = thumb === button;
					thumb.classList.toggle('is-active', active);
					thumb.setAttribute('aria-pressed', active ? 'true' : 'false');
				});
			};

			thumbs.forEach((button) => {
				button.addEventListener('click', () => setImage(button));
			});

			openButton?.addEventListener('click', () => {
				if (!dialog || !dialogImage || typeof dialog.showModal !== 'function') return;

				dialogImage.src = mainImage.src;
				dialogImage.alt = mainImage.alt;
				dialog.showModal();
				closeButton?.focus();
			});

			closeButton?.addEventListener('click', () => dialog?.close());
			dialog?.addEventListener('click', (event) => {
				if (event.target === dialog) dialog.close();
			});
		});
	</script>
</BaseLayout>

<style>
	.product-hero {
		padding: 64px 0 52px;
		background:
			linear-gradient(135deg, var(--color-primary-dark), var(--color-primary)),
			var(--color-primary);
		color: #ffffff;
	}

	.product-hero h1,
	.product-hero .eyebrow {
		color: #ffffff;
	}

	.product-hero .lead {
		color: rgba(255, 255, 255, 0.78);
	}

	.product-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		margin-top: 22px;
	}

	.product-tags a {
		padding: 8px 12px;
		border: 1px solid rgba(255, 255, 255, 0.22);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.1);
		color: #ffffff;
		font-weight: 800;
		text-decoration: none;
	}

	.product-layout {
		display: grid;
		grid-template-columns: minmax(0, 1.7fr) minmax(260px, 0.62fr);
		gap: 28px;
		align-items: start;
	}

	.product-content {
		display: grid;
		gap: 22px;
	}

	.gallery {
		display: grid;
		gap: 12px;
	}

	.gallery-main {
		min-height: clamp(280px, 48vw, 520px);
		margin: 0;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		background: #ffffff;
		overflow: hidden;
	}

	.gallery-open {
		display: block;
		width: 100%;
		height: 100%;
		min-height: inherit;
		padding: 0;
		border: 0;
		background: #ffffff;
		cursor: zoom-in;
	}

	.gallery-main img {
		width: 100%;
		height: 100%;
		object-fit: contain;
	}

	.gallery-placeholder {
		min-height: clamp(280px, 48vw, 520px);
	}

	.gallery-thumbs {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
	}

	.gallery-thumbs button {
		display: grid;
		place-items: center;
		width: 74px;
		height: 58px;
		padding: 0;
		border: 2px solid transparent;
		border-radius: var(--radius-sm);
		background:
			linear-gradient(135deg, rgba(15, 47, 86, 0.08), rgba(74, 163, 223, 0.16)),
			#ffffff;
		cursor: pointer;
		overflow: hidden;
	}

	.gallery-thumbs button.is-active {
		border-color: var(--color-accent);
	}

	.gallery-thumbs img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.gallery-thumbs span {
		width: 34px;
		height: 22px;
		border-radius: 4px;
		background: rgba(15, 47, 86, 0.18);
	}

	.gallery-note {
		margin: 0;
		color: var(--color-muted);
		font-size: 0.95rem;
	}

	.content-block {
		padding: 26px;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		background: #ffffff;
	}

	.spec-table {
		display: grid;
		margin: 0;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		overflow: hidden;
	}

	.spec-table div {
		display: grid;
		grid-template-columns: minmax(130px, 0.38fr) minmax(0, 1fr);
	}

	.spec-table div + div {
		border-top: 1px solid var(--color-border);
	}

	.spec-table dt,
	.spec-table dd {
		margin: 0;
		padding: 12px 14px;
	}

	.spec-table dt {
		background: var(--color-surface-raised);
		color: var(--color-muted);
		font-weight: 800;
	}

	.resource-list {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 240px), 1fr));
		gap: 12px;
	}

	.resource-item {
		display: grid;
		gap: 8px;
		align-content: start;
		padding: 14px;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		background: var(--color-surface-raised);
		text-decoration: none;
	}

	.resource-item__title {
		color: var(--color-primary);
		font-weight: 900;
	}

	.resource-item small {
		color: var(--color-muted);
		font-weight: 600;
		line-height: 1.35;
	}

	.resource-item__action {
		justify-self: start;
		margin-top: 2px;
		padding: 7px 10px;
		border-radius: var(--radius-sm);
		background: var(--color-primary);
		color: #ffffff;
		font-size: 0.88rem;
		font-weight: 900;
	}

	.product-sidebar {
		align-self: start;
		position: sticky;
		top: 92px;
	}

	.side-card {
		padding: 20px;
	}

	.side-card h2 {
		font-size: 1.25rem;
	}

	.side-actions {
		display: grid;
		gap: 10px;
		margin-top: 18px;
	}

	.availability-box {
		display: grid;
		gap: 8px;
		margin: 0 0 16px;
		padding: 14px;
		border: 1px solid rgba(74, 163, 223, 0.26);
		border-radius: var(--radius-sm);
		background: var(--color-primary-soft);
	}

	.availability-box h3 {
		margin: 0;
		color: var(--color-primary);
		font-size: 1rem;
	}

	.availability-box p {
		color: var(--color-muted);
		font-size: 0.95rem;
		margin: 0;
	}

	.side-actions .button {
		width: 100%;
	}

	.final-product-cta {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 18px;
		align-items: center;
		padding: 24px;
		border-radius: var(--radius-md);
		background: var(--color-primary);
		color: #ffffff;
	}

	.final-product-cta h2,
	.final-product-cta .eyebrow {
		color: #ffffff;
	}

	.final-product-cta p {
		color: rgba(255, 255, 255, 0.78);
	}

	.gallery-dialog {
		width: min(94vw, 1100px);
		padding: 0;
		border: 0;
		border-radius: var(--radius-md);
		background: #ffffff;
		box-shadow: 0 30px 80px rgba(0, 0, 0, 0.32);
	}

	.gallery-dialog::backdrop {
		background: rgba(8, 29, 54, 0.72);
	}

	.gallery-dialog img {
		display: block;
		width: 100%;
		max-height: 86vh;
		object-fit: contain;
	}

	.gallery-dialog__close {
		position: absolute;
		top: 12px;
		right: 12px;
		display: grid;
		place-items: center;
		width: 42px;
		height: 42px;
		border: 1px solid rgba(15, 47, 86, 0.16);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.94);
		color: var(--color-primary);
		font-size: 1.7rem;
		line-height: 1;
		cursor: pointer;
	}

	@media (max-width: 900px) {
		.product-layout,
		.final-product-cta {
			grid-template-columns: 1fr;
		}

		.product-sidebar {
			position: static;
		}
	}

	@media (max-width: 620px) {
		.spec-table div {
			grid-template-columns: 1fr;
		}

		.spec-table dd {
			border-top: 1px solid var(--color-border);
		}
	}
</style>
