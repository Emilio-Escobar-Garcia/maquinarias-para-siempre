---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SeoMeta from '../components/SeoMeta.astro';
import { siteConfig } from '../site.config';

interface Props {
	title?: string;
	description?: string;
}

const pageTitle = Astro.props.title ?? siteConfig.name;
const description = Astro.props.description ?? siteConfig.description;
const isIndexable = import.meta.env.PUBLIC_SITE_INDEXABLE === 'true';
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<SeoMeta title={pageTitle} description={description} indexable={isIndexable} />
	</head>
	<body>
		<Header />
		<main>
			<slot />
		</main>
		<Footer />
	</body>
</html>

<style is:global>
	:root {
		color-scheme: light;
		--color-ink: #122033;
		--color-text: #263448;
		--color-muted: #66758a;
		--color-border: #d8e0ea;
		--color-border-strong: #b7c5d6;
		--color-surface: #ffffff;
		--color-surface-raised: #f8fbff;
		--color-subtle: #edf3f8;
		--color-primary: #0f2f56;
		--color-primary-dark: #081d36;
		--color-primary-soft: #dceaf7;
		--color-accent: #4aa3df;
		--color-accent-strong: #2277b9;
		--color-forest: #2f6f5d;
		--color-warning-bg: #fff6df;
		--color-warning: #745419;
		--shadow-soft: 0 18px 45px rgba(12, 32, 56, 0.08);
		--shadow-card: 0 14px 35px rgba(12, 32, 56, 0.1);
		--max-width: 1160px;
		--radius-sm: 8px;
		--radius-md: 12px;
	}

	* {
		box-sizing: border-box;
	}

	html {
		font-family:
			ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial,
			sans-serif;
		background: linear-gradient(180deg, #f8fbff 0%, #eef4f9 40%, #ffffff 100%);
		color: var(--color-text);
	}

	body {
		margin: 0;
		min-width: 320px;
		overflow-x: hidden;
		text-rendering: optimizeLegibility;
	}

	main {
		min-height: 60vh;
	}

	a {
		color: var(--color-accent-strong);
	}

	a:hover {
		color: var(--color-primary);
	}

	a:focus-visible,
	button:focus-visible {
		outline: 3px solid rgba(74, 163, 223, 0.55);
		outline-offset: 3px;
	}

	img {
		max-width: 100%;
		height: auto;
	}

	.container {
		width: min(100% - 32px, var(--max-width));
		margin-inline: auto;
	}

	.section {
		padding: 64px 0;
	}

	.section--compact {
		padding: 36px 0;
	}

	.section--surface {
		background: rgba(255, 255, 255, 0.72);
		border-block: 1px solid rgba(216, 224, 234, 0.7);
	}

	.page-hero {
		position: relative;
		padding: 68px 0 48px;
		background:
			linear-gradient(135deg, rgba(15, 47, 86, 0.97), rgba(13, 67, 105, 0.9)),
			radial-gradient(circle at 85% 10%, rgba(74, 163, 223, 0.32), transparent 32%);
		color: #ffffff;
		overflow: hidden;
	}

	.page-hero::after {
		content: '';
		position: absolute;
		inset: auto -80px -110px auto;
		width: 340px;
		aspect-ratio: 1;
		border: 1px solid rgba(255, 255, 255, 0.12);
		border-radius: 50%;
		background:
			linear-gradient(135deg, rgba(255, 255, 255, 0.08), transparent),
			repeating-linear-gradient(45deg, rgba(255, 255, 255, 0.08) 0 1px, transparent 1px 12px);
	}

	.page-hero .container {
		position: relative;
		z-index: 1;
	}

	.page-hero .lead,
	.page-hero p {
		color: rgba(255, 255, 255, 0.78);
	}

	.eyebrow {
		margin: 0 0 8px;
		color: var(--color-accent-strong);
		font-size: 0.85rem;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}

	.page-hero .eyebrow,
	.hero .eyebrow {
		color: #8ed0ff;
	}

	h1,
	h2,
	h3 {
		line-height: 1.15;
		margin: 0 0 16px;
		color: var(--color-ink);
		letter-spacing: 0;
	}

	.page-hero h1,
	.hero h1 {
		color: #ffffff;
	}

	h1 {
		font-size: clamp(2.2rem, 5vw, 4rem);
		max-width: 820px;
	}

	h2 {
		font-size: clamp(1.5rem, 3vw, 2.25rem);
	}

	h3 {
		font-size: 1.2rem;
	}

	p {
		line-height: 1.65;
		margin: 0 0 16px;
	}

	.lead {
		color: var(--color-muted);
		font-size: 1.12rem;
		line-height: 1.7;
		max-width: 760px;
	}

	.section-heading {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 24px;
		margin-bottom: 24px;
	}

	.section-heading p {
		max-width: 560px;
		color: var(--color-muted);
	}

	.grid {
		display: grid;
		gap: 20px;
	}

	.grid--cards {
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 260px), 340px));
		justify-content: start;
	}

	.card {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		box-shadow: 0 1px 0 rgba(255, 255, 255, 0.75);
		padding: 24px;
	}

	.card p:last-child {
		margin-bottom: 0;
	}

	.button-row {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		margin-top: 24px;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 46px;
		padding: 11px 18px;
		border: 1px solid var(--color-accent);
		border-radius: var(--radius-sm);
		background: linear-gradient(180deg, #54afea, #2784c5);
		color: #ffffff;
		box-shadow: 0 12px 24px rgba(39, 132, 197, 0.24);
		font-weight: 700;
		text-decoration: none;
		transition:
			transform 160ms ease,
			box-shadow 160ms ease,
			background 160ms ease,
			border-color 160ms ease;
	}

	.button:hover {
		border-color: var(--color-accent-strong);
		background: linear-gradient(180deg, #48a7e3, #1d72ad);
		color: #ffffff;
		transform: translateY(-1px);
		box-shadow: 0 16px 28px rgba(39, 132, 197, 0.3);
	}

	.button--secondary {
		border-color: rgba(15, 47, 86, 0.22);
		background: #ffffff;
		box-shadow: none;
		color: var(--color-primary);
	}

	.button--secondary:hover {
		border-color: var(--color-accent);
		color: var(--color-primary-dark);
		background: var(--color-primary-soft);
		box-shadow: none;
	}

	.button--dark {
		border-color: rgba(255, 255, 255, 0.18);
		background: rgba(255, 255, 255, 0.12);
		box-shadow: none;
		color: #ffffff;
	}

	.button--dark:hover {
		border-color: rgba(255, 255, 255, 0.45);
		background: rgba(255, 255, 255, 0.18);
	}

	.list {
		padding-left: 20px;
		line-height: 1.65;
	}

	.notice {
		border-left: 4px solid var(--color-accent);
		background: var(--color-warning-bg);
		border-radius: var(--radius-sm);
		padding: 16px;
		color: var(--color-warning);
	}

	.detail-grid {
		display: grid;
		grid-template-columns: minmax(0, 1.8fr) minmax(280px, 0.8fr);
		gap: 32px;
		align-items: start;
	}

	.meta-list {
		display: grid;
		gap: 10px;
		margin: 0;
	}

	.meta-list div {
		display: grid;
		gap: 4px;
		padding-bottom: 12px;
		border-bottom: 1px solid var(--color-border);
	}

	.meta-list dt {
		color: var(--color-muted);
		font-size: 0.85rem;
		font-weight: 700;
		text-transform: uppercase;
	}

	.meta-list dd {
		margin: 0;
	}

	.visual-placeholder {
		position: relative;
		display: grid;
		place-items: center;
		min-height: 150px;
		border: 1px solid rgba(15, 47, 86, 0.12);
		border-radius: var(--radius-sm);
		background:
			linear-gradient(135deg, rgba(15, 47, 86, 0.06), rgba(74, 163, 223, 0.14)),
			linear-gradient(180deg, rgba(255, 255, 255, 0.6), rgba(255, 255, 255, 0)),
			repeating-linear-gradient(135deg, rgba(15, 47, 86, 0.035) 0 1px, transparent 1px 18px);
		overflow: hidden;
	}

	.visual-placeholder::before {
		content: '';
		position: absolute;
		left: 18%;
		right: 18%;
		bottom: 18%;
		height: 38%;
		border-radius: 14px 14px 0 0;
		background:
			linear-gradient(135deg, rgba(15, 47, 86, 0.18), rgba(74, 163, 223, 0.24)),
			linear-gradient(45deg, transparent 42%, rgba(255, 255, 255, 0.32) 42% 58%, transparent 58%);
		clip-path: polygon(0 100%, 22% 42%, 38% 68%, 56% 28%, 100% 100%);
	}

	.visual-placeholder::after {
		content: '';
		position: absolute;
		top: 22%;
		right: 22%;
		width: 34px;
		aspect-ratio: 1;
		border-radius: 50%;
		background: rgba(74, 163, 223, 0.32);
		box-shadow: 0 0 0 10px rgba(74, 163, 223, 0.08);
	}

	.visual-placeholder span {
		position: relative;
		z-index: 1;
		align-self: end;
		margin-bottom: 18px;
		padding: 5px 9px;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.75);
		color: var(--color-muted);
		font-size: 0.82rem;
		font-weight: 800;
	}

	.empty-state {
		padding: 24px;
		border: 1px dashed var(--color-border-strong);
		border-radius: var(--radius-md);
		background: rgba(255, 255, 255, 0.65);
		color: var(--color-muted);
	}

	.pill-list {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		padding: 0;
		margin: 16px 0 0;
		list-style: none;
	}

	.pill-list li {
		padding: 6px 10px;
		border: 1px solid var(--color-border);
		border-radius: 999px;
		background: #ffffff;
		color: var(--color-muted);
		font-size: 0.9rem;
		font-weight: 700;
	}

	@media (prefers-reduced-motion: reduce) {
		*,
		*::before,
		*::after {
			scroll-behavior: auto !important;
			transition-duration: 0.01ms !important;
			animation-duration: 0.01ms !important;
			animation-iteration-count: 1 !important;
		}
	}

	@media (max-width: 760px) {
		.section {
			padding: 44px 0;
		}

		.detail-grid {
			grid-template-columns: 1fr;
		}

		.section-heading {
			display: block;
		}
	}
</style>
