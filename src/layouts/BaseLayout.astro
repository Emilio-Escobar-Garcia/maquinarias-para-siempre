---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SeoMeta from '../components/SeoMeta.astro';
import { siteConfig } from '../site.config';

interface Props {
	title?: string;
	description?: string;
}

const pageTitle = Astro.props.title ?? siteConfig.name;
const description = Astro.props.description ?? siteConfig.description;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<SeoMeta title={pageTitle} description={description} />
	</head>
	<body>
		<Header />
		<main>
			<slot />
		</main>
		<Footer />
	</body>
</html>

<style is:global>
	:root {
		color-scheme: light;
		--color-text: #1f2933;
		--color-muted: #5f6c7b;
		--color-border: #d8dee6;
		--color-surface: #ffffff;
		--color-subtle: #f4f7f3;
		--color-primary: #315d3c;
		--color-primary-dark: #24452d;
		--color-accent: #b68a36;
		--max-width: 1120px;
	}

	* {
		box-sizing: border-box;
	}

	html {
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
		background: var(--color-subtle);
		color: var(--color-text);
	}

	body {
		margin: 0;
		min-width: 320px;
	}

	main {
		min-height: 60vh;
	}

	a {
		color: var(--color-primary);
	}

	a:hover {
		color: var(--color-primary-dark);
	}

	img {
		max-width: 100%;
		height: auto;
	}

	.container {
		width: min(100% - 32px, var(--max-width));
		margin-inline: auto;
	}

	.section {
		padding: 48px 0;
	}

	.section--compact {
		padding: 28px 0;
	}

	.eyebrow {
		margin: 0 0 8px;
		color: var(--color-primary);
		font-size: 0.85rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
	}

	h1,
	h2,
	h3 {
		line-height: 1.15;
		margin: 0 0 16px;
	}

	h1 {
		font-size: clamp(2rem, 5vw, 3.5rem);
		max-width: 820px;
	}

	h2 {
		font-size: clamp(1.5rem, 3vw, 2.25rem);
	}

	h3 {
		font-size: 1.2rem;
	}

	p {
		line-height: 1.65;
		margin: 0 0 16px;
	}

	.lead {
		color: var(--color-muted);
		font-size: 1.12rem;
		max-width: 760px;
	}

	.grid {
		display: grid;
		gap: 20px;
	}

	.grid--cards {
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
	}

	.card {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 8px;
		padding: 20px;
	}

	.card p:last-child {
		margin-bottom: 0;
	}

	.button-row {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		margin-top: 24px;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 44px;
		padding: 10px 16px;
		border: 1px solid var(--color-primary);
		border-radius: 6px;
		background: var(--color-primary);
		color: #ffffff;
		font-weight: 700;
		text-decoration: none;
	}

	.button:hover {
		background: var(--color-primary-dark);
		color: #ffffff;
	}

	.button--secondary {
		background: transparent;
		color: var(--color-primary);
	}

	.button--secondary:hover {
		background: #e8efe8;
		color: var(--color-primary-dark);
	}

	.list {
		padding-left: 20px;
		line-height: 1.65;
	}

	.notice {
		border-left: 4px solid var(--color-accent);
		background: #fff8e8;
		padding: 16px;
		color: #4a3b1d;
	}

	.detail-grid {
		display: grid;
		grid-template-columns: minmax(0, 2fr) minmax(240px, 1fr);
		gap: 28px;
		align-items: start;
	}

	.meta-list {
		display: grid;
		gap: 10px;
		margin: 0;
	}

	.meta-list div {
		display: grid;
		gap: 4px;
		padding-bottom: 10px;
		border-bottom: 1px solid var(--color-border);
	}

	.meta-list dt {
		color: var(--color-muted);
		font-size: 0.85rem;
		font-weight: 700;
		text-transform: uppercase;
	}

	.meta-list dd {
		margin: 0;
	}

	@media (max-width: 760px) {
		.section {
			padding: 36px 0;
		}

		.detail-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
