---
import { getWhatsAppUrl, siteConfig } from '../site.config';
---

<section class="spare-parts-cta">
	<div>
		<p class="eyebrow">Repuestos</p>
		<h2>{siteConfig.sparePartsTitle}</h2>
		<p>{siteConfig.sparePartsText}</p>
	</div>
	<a class="button button--secondary" href={getWhatsAppUrl(siteConfig.sparePartsMessage)}>Consultar repuestos</a>
</section>

<style>
	.spare-parts-cta {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 18px;
		align-items: center;
		padding: 24px;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		background: var(--color-surface-raised);
	}

	h2 {
		font-size: clamp(1.3rem, 2.4vw, 1.8rem);
	}

	p:not(.eyebrow) {
		max-width: 760px;
		color: var(--color-muted);
	}

	@media (max-width: 760px) {
		.spare-parts-cta {
			grid-template-columns: 1fr;
		}
	}
</style>
