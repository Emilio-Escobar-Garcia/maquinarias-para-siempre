---
import { getWhatsAppUrl, siteConfig } from '../site.config';

interface Props {
	message?: string;
}

const message = Astro.props.message ?? siteConfig.otherReferenceMessage;
---

<section class="reference-cta">
	<div>
		<h2>{siteConfig.otherReferenceTitle}</h2>
		<p>{siteConfig.otherReferenceText}</p>
	</div>
	<a class="button" href={getWhatsAppUrl(message)}>Consultar otra referencia</a>
</section>

<style>
	.reference-cta {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 18px;
		align-items: center;
		padding: 24px;
		border: 1px solid rgba(74, 163, 223, 0.25);
		border-radius: var(--radius-md);
		background: #ffffff;
		box-shadow: var(--shadow-soft);
	}

	h2 {
		font-size: clamp(1.35rem, 2.4vw, 1.85rem);
	}

	p {
		max-width: 760px;
		color: var(--color-muted);
	}

	@media (max-width: 760px) {
		.reference-cta {
			grid-template-columns: 1fr;
		}
	}
</style>
