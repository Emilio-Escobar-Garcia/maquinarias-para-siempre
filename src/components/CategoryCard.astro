---
import type { CollectionEntry } from 'astro:content';

interface Props {
	category: CollectionEntry<'categories'>;
}

const { category } = Astro.props;
---

<article class="card">
	<a class="category-link" href={`/categorias/${category.data.slug}/`}>
		<div class="visual-placeholder category-visual" aria-hidden="true"></div>
		<div class="category-body">
			<p class="eyebrow">Categoría</p>
			<h3>{category.data.name}</h3>
			<p>{category.data.shortDescription}</p>
			<span class="category-action">Ver categoría</span>
		</div>
	</a>
</article>

<style>
	.card {
		height: 100%;
		padding: 0;
		overflow: hidden;
		transition:
			transform 160ms ease,
			border-color 160ms ease,
			box-shadow 160ms ease;
	}

	.card:hover {
		border-color: rgba(74, 163, 223, 0.55);
		box-shadow: var(--shadow-card);
		transform: translateY(-2px);
	}

	.category-link {
		display: flex;
		flex-direction: column;
		height: 100%;
		min-height: 360px;
		color: inherit;
		text-decoration: none;
	}

	.category-visual {
		width: 100%;
		aspect-ratio: 4 / 3;
		min-height: 0;
		border-width: 0 0 1px;
		border-radius: 0;
	}

	.category-body {
		display: flex;
		flex: 1;
		flex-direction: column;
		padding: 20px;
	}

	h3 {
		margin-bottom: 8px;
		color: var(--color-ink);
	}

	p:not(.eyebrow) {
		color: var(--color-muted);
		display: -webkit-box;
		min-height: calc(1.65em * 3);
		margin-bottom: 18px;
		overflow: hidden;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 3;
		line-clamp: 3;
	}

	.category-action {
		margin-top: auto;
		color: var(--color-primary);
		font-weight: 800;
	}

	@media (max-width: 520px) {
		.category-link {
			min-height: 350px;
		}
	}
</style>
