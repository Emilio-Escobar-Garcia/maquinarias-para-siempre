---
import type { CollectionEntry } from 'astro:content';

interface Props {
	product: CollectionEntry<'products'>;
}

const { product } = Astro.props;
const isDemoProduct = product.data.slug === 'producto-demostracion';
const firstImage = product.data.images?.[0];
const image =
	typeof firstImage === 'string'
		? { src: firstImage, alt: `Imagen de ${product.data.name}` }
		: firstImage;
---

<article class="card product-card">
	<a class="card-link" href={`/productos/${product.data.slug}/`} aria-label={`Ver ${product.data.name}`}>
		{
			image ? (
				<img class="product-visual product-image" src={image.src} alt={image.alt} loading="lazy" />
			) : (
				<div class="visual-placeholder product-visual" aria-hidden="true">
					{isDemoProduct && <span>Imagen del producto</span>}
				</div>
			)
		}
		<div class="product-body">
			<div class="card-meta">
				<span>Producto</span>
				{product.data.featured && <span class="tag">Destacado</span>}
			</div>
			<h3>{product.data.name}</h3>
			<p>{product.data.shortDescription}</p>
			<span class="read-more">Ver ficha</span>
		</div>
	</a>
</article>

<style>
	.product-card {
		padding: 0;
		overflow: hidden;
		transition:
			transform 160ms ease,
			border-color 160ms ease,
			box-shadow 160ms ease;
	}

	.product-card:hover {
		border-color: rgba(74, 163, 223, 0.55);
		box-shadow: var(--shadow-card);
		transform: translateY(-2px);
	}

	.card-link {
		display: flex;
		flex-direction: column;
		height: 100%;
		color: inherit;
		text-decoration: none;
	}

	.product-visual {
		width: 100%;
		aspect-ratio: 16 / 9;
		min-height: 0;
		border-width: 0 0 1px;
		border-radius: 0;
	}

	.product-image {
		display: block;
		height: auto;
		object-fit: cover;
		border-bottom: 1px solid var(--color-border);
		background: #ffffff;
	}

	.product-body {
		display: flex;
		flex: 1;
		flex-direction: column;
		gap: 10px;
		padding: 22px;
	}

	.card-meta {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 10px;
		color: var(--color-accent-strong);
		font-size: 0.8rem;
		font-weight: 800;
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}

	h3 {
		margin-bottom: 0;
		color: var(--color-ink);
	}

	p {
		color: var(--color-muted);
		display: -webkit-box;
		min-height: calc(1.65em * 3);
		overflow: hidden;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 3;
		line-clamp: 3;
	}

	.tag {
		display: inline-block;
		padding: 4px 8px;
		border-radius: 4px;
		background: var(--color-primary-soft);
		color: var(--color-primary);
		font-size: 0.85rem;
		font-weight: 700;
		letter-spacing: 0;
		text-transform: none;
	}

	.read-more {
		margin-top: auto;
		color: var(--color-primary);
		font-weight: 800;
	}
</style>
