---
import type { CollectionEntry } from 'astro:content';

interface Props {
	brand: CollectionEntry<'brands'>;
}

const { brand } = Astro.props;
---

<article class="card">
	<a class="brand-link" href={`/marcas/${brand.data.slug}/`}>
		<div class="brand-mark" aria-hidden="true">{brand.data.name.slice(0, 2).toUpperCase()}</div>
		<div class="brand-body">
			<p class="eyebrow">Marca</p>
			<h3>{brand.data.name}</h3>
			<p>{brand.data.shortDescription}</p>
		</div>
	</a>
</article>

<style>
	.card {
		height: 100%;
		padding: 0;
		transition:
			transform 160ms ease,
			border-color 160ms ease,
			box-shadow 160ms ease;
	}

	.card:hover {
		border-color: rgba(74, 163, 223, 0.55);
		box-shadow: var(--shadow-card);
		transform: translateY(-2px);
	}

	.brand-link {
		display: flex;
		flex-direction: column;
		height: 100%;
		min-height: 260px;
		padding: 22px;
		color: inherit;
		text-decoration: none;
	}

	.brand-mark {
		display: grid;
		place-items: center;
		width: 74px;
		height: 74px;
		border-radius: var(--radius-md);
		background:
			linear-gradient(135deg, rgba(15, 47, 86, 0.92), rgba(74, 163, 223, 0.8)),
			var(--color-primary);
		color: #ffffff;
		font-weight: 900;
		letter-spacing: 0.06em;
	}

	.brand-body {
		display: flex;
		flex: 1;
		flex-direction: column;
		margin-top: 18px;
	}

	h3 {
		margin-bottom: 8px;
		color: var(--color-ink);
	}

	p:not(.eyebrow) {
		color: var(--color-muted);
		display: -webkit-box;
		min-height: calc(1.65em * 3);
		overflow: hidden;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 3;
		line-clamp: 3;
	}

	@media (max-width: 520px) {
		.brand-link {
			min-height: 250px;
		}
	}
</style>
